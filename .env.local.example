# ─── Supabase ───────────────────────────────────────────────────────────
# Lấy từ: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── JWT ────────────────────────────────────────────────────────────────
# Tạo chuỗi ngẫu nhiên dài >= 32 ký tự
# Lệnh: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# ─── WebAuthn ───────────────────────────────────────────────────────────
# Domain của app (localhost cho dev)
NEXT_PUBLIC_APP_DOMAIN=localhost
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Web Push (VAPID) ───────────────────────────────────────────────────
# Tạo keys: node -e "const wp=require('web-push'); const keys=wp.generateVAPIDKeys(); console.log(keys)"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@alohahome.app

# ─── Dev-only: impersonate endpoint (T-022) ─────────────────────────────
# Token để bypass password cho Phase E auto test (curl / Claude in Chrome).
# Endpoint /api/dev/impersonate chỉ active khi NODE_ENV !== 'production' VÀ var này có giá trị.
# Generate: openssl rand -hex 32
# CẢNH BÁO: KHÔNG set biến này trên Vercel Production hay Preview environment.
DEV_IMPERSONATE_TOKEN=
