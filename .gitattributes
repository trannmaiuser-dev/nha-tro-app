# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source code (force LF)
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf

# Config files
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.xml   text eol=lf

# Docs
*.md    text eol=lf
*.txt   text eol=lf

# SQL / Migrations
*.sql   text eol=lf

# Styles
*.css   text eol=lf
*.scss  text eol=lf
*.html  text eol=lf

# Shell scripts (LF bắt buộc)
*.sh    text eol=lf

# Windows scripts (CRLF bắt buộc)
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary files (không touch)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.zip   binary
*.tar.gz binary
*.mp4   binary
*.mp3   binary

# Lock files (không touch)
package-lock.json -text
yarn.lock         -text
pnpm-lock.yaml    -text
